# Hugging Face access token (optional for public datasets).
# Create a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Audio duration filters ─────────────────────────────────────────────────────
# Exclude samples shorter than this duration in seconds (no filter when unset).
AUDIO_DURATION_MIN=0.5
# Clip samples longer than this duration in seconds.
AUDIO_DURATION_MAX=10.0

# ── Detection test defaults ────────────────────────────────────────────────────
# Distance (metres) beyond which a warning is shown in the form.
DETECTION_RELIABLE_RANGE_M=100.0
# Distance (metres) beyond which a microphone is not expected to detect a drone.
# Analysis splits results into within-range and beyond-range sections at this boundary.
MIC_DETECT_MAX_M=100.0
# Directory containing drone-audio/ and non-drone-audio/ sub-directories.
DETECTION_AUDIO_DIR=.data/drone-audio-detection-samples/audio
# Directory where session CSV files are written.
DETECTION_OUTPUT_DIR=.data/detection-tests

# ── Data pipeline defaults ─────────────────────────────────────────────────────
# Directory for the cached Arrow dataset.
DATA_CACHE_DIR=.data/drone-audio-detection-samples
# Directory where unpacked WAV files are stored.
DATA_AUDIO_DIR=.data/drone-audio-detection-samples/audio
